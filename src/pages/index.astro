---
export const prerender = false;

import MainLayout from "../layouts/MainLayout.astro";
import LandingPage from "../components/LandingPage.astro";
import { drizzle } from "drizzle-orm/d1";
import { eq } from "drizzle-orm";
import * as schema from "../db/schema";

// 1. Redirección para usuarios logueados (PRIORIDAD ALTA)
const sessionCookie = Astro.cookies.get("better-auth.session_token");

// 2. Modo Mantenimiento
const maintenance = import.meta.env.PUBLIC_MAINTENANCE_MODE === 'true';

let showLandingPage = false;
let isAdmin = false;

// Si hay sesión, verificar el rol
if (sessionCookie?.value) {
    try {
        const locals = Astro.locals as any;
        const env = locals.runtime?.env || locals.env;
        
        if (env?.DB) {
            const db = drizzle(env.DB, { schema });
            
            const session = await db
                .select()
                .from(schema.session)
                .where(eq(schema.session.token, sessionCookie.value))
                .get();
            
            if (session) {
                const user = await db
                    .select()
                    .from(schema.user)
                    .where(eq(schema.user.id, session.userId))
                    .get();
                
                isAdmin = user?.role === 'admin';
            }
        }
    } catch (error) {
        console.error("[Index] Error checking user role:", error);
    }
}

// Lógica de acceso:
// - Si NO hay mantenimiento: todos ven la landing
// - Si HAY mantenimiento: solo admins ven la landing
if (!maintenance || isAdmin) {
    showLandingPage = true;
}
---

{showLandingPage ? (
    <LandingPage />
) : (
    <MainLayout
        title="LFR Telemetry - Coming Soon"
        fullWidth={true}
        sidebarHidden={true}
        hideMenu={true}
    >
        <main
            class="min-h-screen flex flex-col items-center justify-center bg-[#0a0a0a] relative overflow-hidden text-center px-6"
        >
            <!-- Background Effects -->
            <div
                class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(249,115,22,0.05),transparent_50%)]"
            >
            </div>
            <div
                class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 brightness-100 contrast-150"
            >
            </div>
    
            <div class="relative z-10 max-w-4xl mx-auto space-y-8">
                <!-- Badge -->
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 bg-white/5 border border-white/10 rounded-full backdrop-blur-md"
                >
                    <span class="w-2 h-2 rounded-full bg-brand-orange animate-pulse"
                    ></span>
                    <span
                        class="text-[10px] font-mono uppercase tracking-[0.2em] text-white/50"
                        >System Initializing</span
                    >
                </div>
    
                <!-- Main Title -->
                <h1
                    class="text-6xl md:text-8xl font-black tracking-tighter text-white"
                >
                    LFR <span
                        class="text-transparent bg-clip-text bg-gradient-to-b from-brand-orange to-orange-600"
                        >PRO</span
                    >
                </h1>
    
                <p
                    class="text-xl md:text-2xl text-white/40 font-medium max-w-2xl mx-auto leading-relaxed"
                >
                    The next generation of robotics telemetry and simulation is
                    loading.
                    <span class="block text-brand-blue mt-2"
                        >Prepare for deployment.</span
                    >
                </p>
    
                <!-- Loading Bar -->
                <div
                    class="w-full max-w-md mx-auto h-1 bg-white/10 rounded-full overflow-hidden mt-12"
                >
                    <div
                        class="h-full bg-brand-orange animate-[width_3s_ease-in-out_infinite] w-1/3"
                    >
                    </div>
                </div>
            </div>
        </main>
    </MainLayout>
)}
