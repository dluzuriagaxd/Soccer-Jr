---
import MainLayout from "../layouts/MainLayout.astro";
import LoginForm from "../components/auth/LoginForm";

const maintenance = import.meta.env.PUBLIC_MAINTENANCE_MODE === "true";
---

<MainLayout title="Login" sidebarHidden={true} fullWidth={true}>
    <div class="flex flex-col items-center justify-center min-h-[70vh] gap-8">
        <LoginForm client:load hideRegisterLink={maintenance} />
    </div>
</MainLayout>
