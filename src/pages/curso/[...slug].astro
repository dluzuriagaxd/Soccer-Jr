---
export const prerender = false;

import { getCollection, getEntry } from "astro:content";
import LessonLayout from "../../layouts/LessonLayout.astro";

const { slug } = Astro.params;

console.log("========================================");
console.log("[COURSE PAGE] Loading lesson:", slug);
console.log("========================================");

if (!slug) {
  return Astro.redirect("/404");
}

const entry = await getEntry("lessons", slug);

if (!entry) {
  return Astro.redirect("/404");
}

const { Content, headings } = await entry.render();

// --- AUTH CHECK ---
import { drizzle } from "drizzle-orm/d1";
import { eq } from "drizzle-orm";
import * as schema from "../../db/schema";

const sessionCookie = Astro.cookies.get("better-auth.session_token");
let isAdmin = false;

if (sessionCookie?.value) {
  try {
    const locals = Astro.locals as any;
    const env = locals.runtime?.env || locals.env;

    if (env?.DB) {
      const db = drizzle(env.DB, { schema });
      // Better-auth tokens in cookies might have a .signature part
      const tokenId = sessionCookie.value.split(".")[0];
      console.log("[Lesson Page] Searching for token ID:", tokenId);
      const session = await db
        .select()
        .from(schema.session)
        .where(eq(schema.session.token, tokenId))
        .get();

      if (session) {
        const user = await db
          .select()
          .from(schema.user)
          .where(eq(schema.user.id, session.userId))
          .get();

        isAdmin = user?.role === "admin";
        console.log(
          "[Lesson Page] User found:",
          user?.email,
          "| Role:",
          user?.role,
          "| isAdmin:",
          isAdmin,
        );
      } else {
        console.log("[Lesson Page] No session found for token");
      }
    } else {
      console.log("[Lesson Page] No DB available");
    }
  } catch (error) {
    console.error("[Lesson] Error checking user role:", error);
  }
}

// Pass to locals for the AdminOnly component to read
Astro.locals.isAdmin = isAdmin;
console.log(
  "[Lesson Page] Setting Astro.locals.isAdmin =",
  isAdmin,
  "for email:",
  sessionCookie ? "has session" : "no session",
);
// ------------------

import AdminOnly from "../../components/AdminOnly.astro";

// Fetch and sort all lessons to find navigation links
const allLessons = (await getCollection("lessons")).sort(
  (a, b) => a.data.order - b.data.order,
);
const currentIndex = allLessons.findIndex(
  (lesson) => lesson.slug === entry.slug,
);

const prevLesson =
  currentIndex > 0
    ? {
        slug: allLessons[currentIndex - 1].slug,
        title: allLessons[currentIndex - 1].data.title,
      }
    : undefined;

const nextLesson =
  currentIndex < allLessons.length - 1
    ? {
        slug: allLessons[currentIndex + 1].slug,
        title: allLessons[currentIndex + 1].data.title,
      }
    : undefined;
---

<LessonLayout
  title={entry.data.title}
  slug={entry.slug}
  headings={headings}
  prevLesson={prevLesson}
  nextLesson={nextLesson}
>
  <Content components={{ AdminOnly }} />
</LessonLayout>
